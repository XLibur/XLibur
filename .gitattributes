# Source https://help.github.com/articles/dealing-with-line-endings
#
# Normalize all text files to LF inside the repository and check them out with
# CRLF on every platform. This keeps the working tree consistent with
# .editorconfig (end_of_line = crlf) so edits never produce line-ending churn.
* text=auto eol=crlf

# C# files: normalize + enable language-aware diffs.
*.cs text diff=csharp eol=crlf

# Binary files: never normalize or convert line endings.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.tiff binary
*.webp binary
*.pcx binary
*.wmf binary
*.emf binary
*.ico binary
*.ttf binary
*.dll binary
*.xlsx binary
*.xlsm binary
