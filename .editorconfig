root = true

[*]
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8-bom
max_line_length = 120

# 4 space indentation
[*.cs]
indent_style = space
indent_size = 4

# 2 space indentation for project/build files
[*.{csproj,props,targets,slnx,nuspec}]
indent_style = space
indent_size = 2

# 2 space indentation for config files
[*.{json,yml,yaml}]
indent_style = space
indent_size = 2

[*.xml]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
